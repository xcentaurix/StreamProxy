<?xml version="1.0" encoding="UTF-8"?>
<skin>
    <!-- StreamProxy Custom Skin -->
    <screen name="StreamProxySetup" position="center,center" size="680,480" title="Configurazione Stream Proxy">
        <!-- Barra superiore con pulsanti colorati -->
        <ePixmap pixmap="skin_default/buttons/red.png" position="25,0" size="140,40" alphatest="on" />
        <ePixmap pixmap="skin_default/buttons/green.png" position="165,0" size="140,40" alphatest="on" />
        <ePixmap pixmap="skin_default/buttons/yellow.png" position="305,0" size="140,40" alphatest="on" />
        <ePixmap pixmap="skin_default/buttons/blue.png" position="445,0" size="140,40" alphatest="on" />
        
        <widget name="key_red" position="25,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#9f1313" transparent="1" />
        <widget name="key_green" position="165,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#1f771f" transparent="1" />
        <widget name="key_yellow" position="305,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#a08500" transparent="1" />
        <widget name="key_blue" position="445,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#18188b" transparent="1" />
        
        <!-- Titolo e descrizione -->
        <widget name="title" position="20,50" size="640,30" font="Regular;24" halign="center" valign="center" foregroundColor="#00bab329" />
        <widget name="description" position="20,85" size="640,40" font="Regular;18" halign="center" valign="center" />
        
        <!-- Separatore -->
        <eLabel position="20,130" size="640,1" backgroundColor="#999999" />
        
        <!-- Lista configurazione -->
        <widget name="config" position="20,140" size="640,240" enableWrapAround="1" scrollbarMode="showOnDemand" />
        
        <!-- Separatore -->
        <eLabel position="20,390" size="640,1" backgroundColor="#999999" />
        
        <!-- Stato -->
        <widget name="status" position="20,400" size="640,40" font="Regular;20" halign="center" valign="center" foregroundColor="#00bab329" />
        
        <!-- Barra di caricamento -->
        <widget name="loading" position="20,450" size="640,20" pixmap="skin_default/progress_bg.png" zPosition="2" transparent="1" />
        <widget name="loading_progress" position="20,450" size="0,20" pixmap="skin_default/progress.png" zPosition="3" transparent="1" />
    </screen>
    
    <screen name="ChannelSelector" position="center,center" size="720,560" title="Seleziona canali per Stream Proxy">
        <!-- Barra superiore con pulsanti colorati -->
        <ePixmap pixmap="skin_default/buttons/red.png" position="25,0" size="140,40" alphatest="on" />
        <ePixmap pixmap="skin_default/buttons/green.png" position="165,0" size="140,40" alphatest="on" />
        <ePixmap pixmap="skin_default/buttons/yellow.png" position="305,0" size="140,40" alphatest="on" />
        <ePixmap pixmap="skin_default/buttons/blue.png" position="445,0" size="140,40" alphatest="on" />
        
        <widget name="key_red" position="25,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#9f1313" transparent="1" />
        <widget name="key_green" position="165,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#1f771f" transparent="1" />
        <widget name="key_yellow" position="305,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#a08500" transparent="1" />
        <widget name="key_blue" position="445,0" zPosition="1" size="140,40" font="Regular;20" halign="center" valign="center" backgroundColor="#18188b" transparent="1" />
        
        <!-- Separatore -->
        <eLabel position="20,50" size="680,1" backgroundColor="#999999" />
        
        <!-- Istruzioni -->
        <widget name="instructions" position="20,60" size="680,40" font="Regular;18" halign="center" valign="center" />
        
        <!-- Campo di ricerca -->
        <widget name="search_label" position="20,110" size="100,30" font="Regular;18" halign="left" valign="center" />
        <widget name="search" position="130,110" size="570,30" font="Regular;18" halign="left" valign="center" />
        
        <!-- Lista canali -->
        <widget name="list" position="20,150" size="680,350" enableWrapAround="1" scrollbarMode="showOnDemand" />
        
        <!-- Separatore -->
        <eLabel position="20,510" size="680,1" backgroundColor="#999999" />
        
        <!-- Stato -->
        <widget name="status" position="20,520" size="680,30" font="Regular;20" halign="center" valign="center" foregroundColor="#00bab329" />
    </screen>
</skin>